# Analytics & Search Console verification.
# Set these in Vercel → Project Settings → Environment Variables (Production).
# All are OPTIONAL — each block in src/components/Analytics.astro renders only
# when its value is present. These IDs are PUBLIC (they appear in page HTML),
# hence the PUBLIC_ prefix required by Astro to expose them at build time.

# Google Analytics 4 — Measurement ID (Admin → Data Streams → web stream)
PUBLIC_GA4_ID=

# Microsoft Clarity — Project ID (clarity.microsoft.com → Settings → Setup)
PUBLIC_CLARITY_ID=

# Google Search Console — ONLY needed for the meta-tag method.
# Leave blank if you verify ownership via DNS TXT instead.
PUBLIC_GSC_VERIFICATION=

# Bing Webmaster — ONLY if you verify Bing independently.
# Leave blank if you import the site from GSC (the easy path).
PUBLIC_BING_VERIFICATION=
