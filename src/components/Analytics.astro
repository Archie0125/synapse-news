---
// Third-party analytics + search-console verification.
// Every ID comes from a PUBLIC_ env var (set in Vercel → Project Settings →
// Environment Variables), so nothing is committed to git. Each block renders
// only when its var is present, so unconfigured platforms cost zero bytes.
const gaId = import.meta.env.PUBLIC_GA4_ID ?? 'G-C4TTJRZR4X';
const clarityId = import.meta.env.PUBLIC_CLARITY_ID ?? 'xflja7qzj9';
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION;
const bingVerification = import.meta.env.PUBLIC_BING_VERIFICATION;
---

{/* Search Console / Bing ownership — only needed for the meta-tag method
    (skip these vars entirely if you verify via DNS TXT instead). */}
{gscVerification && <meta name="google-site-verification" content={gscVerification} />}
{bingVerification && <meta name="msvalidate.01" content={bingVerification} />}

{/* GA4 + Microsoft Clarity, deferred off the critical path. The queue stubs
    run immediately (cheap, just buffer calls); the actual gtag.js/clarity.ms
    scripts inject on idle-after-load or shortly after the first interaction,
    whichever comes first. Keeps their parse/eval cost away from LCP and the
    first tap (INP). Trade-off: visitors who bounce before the delay are not
    recorded — expected, do not "fix". Clarity must stay on the main thread
    (session recording breaks in a web worker, so no Partytown). */}
{(gaId || clarityId) && (
  <script is:inline set:html={`
    (function(){
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.gtag = gtag;
      ${gaId ? `gtag('js', new Date()); gtag('config', '${gaId}');` : ''}
      ${clarityId ? `window.clarity = window.clarity || function(){(window.clarity.q = window.clarity.q || []).push(arguments)};` : ''}

      var loaded = false;
      function inject(src){
        var s = document.createElement('script');
        s.async = true;
        s.src = src;
        document.head.appendChild(s);
      }
      function load(){
        if (loaded) return;
        loaded = true;
        ${gaId ? `inject('https://www.googletagmanager.com/gtag/js?id=${gaId}');` : ''}
        ${clarityId ? `inject('https://www.clarity.ms/tag/${clarityId}?ref=bwt');` : ''}
      }
      // Defer past the interaction's own frame so parsing gtag.js does not
      // become the very INP regression this is meant to avoid.
      function onInteract(){ setTimeout(load, 300); }
      ['pointerdown','keydown','touchstart'].forEach(function(ev){
        addEventListener(ev, onInteract, { once: true, passive: true });
      });
      addEventListener('load', function(){
        if ('requestIdleCallback' in window) requestIdleCallback(load, { timeout: 4000 });
        else setTimeout(load, 4000);
      });
    })();
  `}></script>
)}
