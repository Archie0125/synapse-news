---
import { getRelativeTimeLocalized, formatDateLocalized, type Lang } from '../lib/i18n';

interface Props {
  date: Date;
  readingTime: string;
  lang?: Lang;
}

const { date, readingTime, lang = 'en' } = Astro.props;
---

<div class="flex items-center gap-3 text-sm text-[var(--color-text-muted)]">
  <time datetime={date.toISOString()} title={formatDateLocalized(date, lang)}>
    {getRelativeTimeLocalized(date, lang)}
  </time>
  <span class="w-1 h-1 rounded-full bg-[var(--color-text-muted)]"></span>
  <span>{readingTime}</span>
</div>
