---
import { CATEGORIES } from '../lib/categories';
import { t, getCategoryName, type Lang } from '../lib/i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
---

<header class="sticky top-0 z-50 bg-[var(--color-bg)]/80 backdrop-blur-lg border-b border-[var(--color-border)]">
  <div class="container flex items-center justify-between h-16">
    <a href={`/${lang}/`} class="flex items-center gap-2 shrink-0">
      <span class="text-xl font-headline font-bold tracking-tight">{t(lang, 'site.name')}</span>
      <span class="hidden sm:inline text-xs font-medium text-[var(--color-text-muted)] bg-[var(--color-surface)] px-2 py-0.5 rounded-full">
        {t(lang, 'site.tagline')}
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {CATEGORIES.map(cat => (
        <a
          href={`/${lang}/${cat.slug}/`}
          class="px-3 py-1.5 text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-text)] rounded-lg hover:bg-[var(--color-surface)] transition-colors"
        >
          {getCategoryName(lang, cat.slug)}
        </a>
      ))}
      <a
        href={`/${lang}/threads/`}
        class="px-3 py-1.5 text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-text)] rounded-lg hover:bg-[var(--color-surface)] transition-colors"
      >
        Threads
      </a>
    </nav>

    <div class="flex items-center gap-2">
      <LanguageSwitcher lang={lang} />

      <button
        id="theme-toggle"
        class="p-2 rounded-lg hover:bg-[var(--color-surface)] transition-colors"
        aria-label="Toggle theme"
      >
        <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5" />
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
        <svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg hover:bg-[var(--color-surface)]"
        aria-label="Menu"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="hidden md:hidden border-t border-[var(--color-border)] bg-[var(--color-bg)]">
    <div class="container py-3 flex flex-col gap-1">
      {CATEGORIES.map(cat => (
        <a
          href={`/${lang}/${cat.slug}/`}
          class="px-3 py-2 text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-text)] rounded-lg hover:bg-[var(--color-surface)]"
        >
          {getCategoryName(lang, cat.slug)}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });

  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
  document.querySelectorAll('#mobile-menu a').forEach(link => {
    link.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.add('hidden');
    });
  });
</script>
