---
import CategoryPill from './CategoryPill.astro';
import { getRelativeTimeLocalized, getReadingTimeLocalized, t, type Lang } from '../lib/i18n';

interface Props {
  title: string;
  summary: string;
  category: string;
  publishedAt: Date;
  slug: string;
  content: string;
  type?: string;
  lang?: Lang;
}

const { title, summary, category, publishedAt, slug, content, type = 'news', lang = 'en' } = Astro.props;
const readingTime = getReadingTimeLocalized(content, lang);
---

<section class="relative bg-gradient-to-br from-[var(--color-surface)] to-[var(--color-bg)] rounded-2xl p-6 md:p-10 mb-8 border border-[var(--color-border)]">
  <div class="max-w-2xl">
    <div class="flex items-center gap-3 mb-4">
      <CategoryPill category={category} lang={lang} />
      {type === 'analysis' && (
        <span class="text-xs font-semibold uppercase tracking-wider text-amber-500">
          {t(lang, 'article.analysis')}
        </span>
      )}
    </div>

    <a href={`/${lang}/${category}/${slug}/`} class="group block">
      <h2 class="font-headline text-2xl md:text-[36px] leading-tight mb-3 text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">
        {title}
      </h2>
    </a>

    <p class="text-base md:text-lg text-[var(--color-text-muted)] mb-4 line-clamp-3">
      {summary}
    </p>

    <div class="flex items-center gap-3 text-sm text-[var(--color-text-muted)]">
      <time datetime={publishedAt.toISOString()}>{getRelativeTimeLocalized(publishedAt, lang)}</time>
      <span class="w-1 h-1 rounded-full bg-[var(--color-text-muted)]"></span>
      <span>{readingTime}</span>
    </div>
  </div>
</section>
