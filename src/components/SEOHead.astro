---
import { SITE } from '../data/site';
import { t, type Lang } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  article?: boolean;
  publishedAt?: Date;
  lang?: Lang;
}

const {
  title,
  description,
  ogImage = '/og-default.png',
  article = false,
  publishedAt,
  lang = 'en',
} = Astro.props;

const siteDescription = t(lang, 'site.description');
const desc = description || siteDescription;
const pageTitle = title ? `${title} - ${SITE.name}` : SITE.name;
const canonicalURL = new URL(Astro.url.pathname, SITE.url);
const ogImageURL = new URL(ogImage, SITE.url);
const htmlLang = lang === 'zh' ? 'zh-TW' : 'en';
const alternateLang = lang === 'zh' ? 'en' : 'zh';
const alternatePath = Astro.url.pathname.replace(`/${lang}/`, `/${alternateLang}/`);
const alternateURL = new URL(alternatePath, SITE.url);
---

<title>{pageTitle}</title>
<meta name="description" content={desc} />
<link rel="canonical" href={canonicalURL} />
<link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />
<link rel="alternate" hreflang={htmlLang} href={canonicalURL} />
<link rel="alternate" hreflang={alternateLang === 'zh' ? 'zh-TW' : 'en'} href={alternateURL} />

<!-- Open Graph -->
<meta property="og:type" content={article ? 'article' : 'website'} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={desc} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:locale" content={lang === 'zh' ? 'zh_TW' : 'en_US'} />
<meta property="og:locale:alternate" content={lang === 'zh' ? 'en_US' : 'zh_TW'} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={desc} />
<meta name="twitter:image" content={ogImageURL} />

{article && publishedAt && (
  <>
    <meta property="article:published_time" content={publishedAt.toISOString()} />
    <meta property="article:author" content={SITE.author} />
  </>
)}

<!-- JSON-LD -->
{article ? (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'NewsArticle',
    headline: title,
    description: desc,
    datePublished: publishedAt?.toISOString(),
    inLanguage: htmlLang,
    author: { '@type': 'Organization', name: SITE.author },
    publisher: {
      '@type': 'Organization',
      name: SITE.name,
      logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', SITE.url).href },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.href },
    image: ogImageURL.href,
  })} />
) : (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    description: siteDescription,
    url: SITE.url,
    inLanguage: ['en', 'zh-TW'],
  })} />
)}
