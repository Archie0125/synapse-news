---
import { getRelativeTimeLocalized, type Lang } from '../lib/i18n';

interface Props {
  title: string;
  category: string;
  publishedAt: Date;
  slug: string;
  index: number;
  lang?: Lang;
}

const { title, category, publishedAt, slug, index, lang = 'en' } = Astro.props;
---

<a href={`/${lang}/${category}/${slug}/`} class="group flex items-start gap-3 py-3 border-b border-[var(--color-border)] last:border-0">
  <span class="text-2xl font-headline font-bold text-[var(--color-border)] group-hover:text-[var(--color-accent)] transition-colors shrink-0 w-8">
    {String(index).padStart(2, '0')}
  </span>
  <div>
    <h4 class="text-sm font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors line-clamp-2 mb-1">
      {title}
    </h4>
    <time class="text-xs text-[var(--color-text-muted)]" datetime={publishedAt.toISOString()}>
      {getRelativeTimeLocalized(publishedAt, lang)}
    </time>
  </div>
</a>
