---
import { t, type Lang } from '../lib/i18n';

interface TrendingItem {
  title: string;
  category: string;
  slug: string;
}

interface Props {
  items: TrendingItem[];
  lang?: Lang;
}

const { items, lang = 'en' } = Astro.props;

// Duplicate items for seamless infinite loop
const loopItems = [...items, ...items];
---

{items.length > 0 && (
  <div class="border-b border-[var(--color-border)] py-3 mb-8 overflow-hidden">
    <div class="container flex items-center gap-4">
      <span class="shrink-0 text-xs font-bold uppercase tracking-wider text-[var(--color-accent)]">
        {t(lang, 'home.trending')}
      </span>
      <div class="trending-track-wrapper">
        <div class="trending-track">
          {loopItems.map((item, i) => (
            <a
              href={`/${lang}/${item.category}/${item.slug}/`}
              class="shrink-0 flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors"
            >
              <span class="text-xs font-bold text-[var(--color-accent)]">
                {String((i % items.length) + 1).padStart(2, '0')}
              </span>
              <span class="whitespace-nowrap">
                {item.title.length > 60 ? item.title.slice(0, 60) + '...' : item.title}
              </span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
)}

<style>
  .trending-track-wrapper {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 40px, black calc(100% - 40px), transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 40px, black calc(100% - 40px), transparent);
  }

  .trending-track {
    display: flex;
    gap: 2rem;
    width: max-content;
    animation: marquee 30s linear infinite;
  }

  .trending-track:hover {
    animation-play-state: paused;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
