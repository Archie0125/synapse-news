---
import BaseLayout from './BaseLayout.astro';
import CategoryPill from '../components/CategoryPill.astro';
import Byline from '../components/Byline.astro';
import SourcesList from '../components/SourcesList.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import ShareButtons from '../components/ShareButtons.astro';
import ViewCounter from '../components/ViewCounter.astro';
import { getReadingTimeLocalized, t, type Lang } from '../lib/i18n';

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  summary: string;
  category: string;
  publishedAt: Date;
  modifiedAt?: Date;
  sources: Array<{ name: string; url: string }>;
  tags: string[];
  content: string;
  relatedSlugs?: string[];
  type?: string;
  lang?: Lang;
  slug?: string;
  faqs?: FAQ[];
}

const {
  title,
  summary,
  category,
  publishedAt,
  modifiedAt,
  sources,
  tags,
  content,
  relatedSlugs = [],
  type = 'news',
  lang = 'en',
  slug = '',
  faqs = [],
} = Astro.props;

const readingTime = getReadingTimeLocalized(content, lang);
// Approximate word count from markdown body (strip markdown tokens cheaply)
const wordCount = content
  ? content.replace(/[#*_`~>\-\[\]\(\)!]/g, ' ').trim().split(/\s+/).filter(Boolean).length
  : undefined;
---

<BaseLayout
  title={title}
  description={summary}
  article={true}
  publishedAt={publishedAt}
  modifiedAt={modifiedAt}
  lang={lang}
  category={category}
  tags={tags}
  sources={sources}
  faqs={faqs}
  wordCount={wordCount}
>
  <div id="reading-progress" class="reading-progress"></div>
  <script is:inline>
    window.addEventListener('scroll', () => {
      const el = document.getElementById('reading-progress');
      if (!el) return;
      const h = document.documentElement.scrollHeight - window.innerHeight;
      el.style.width = h > 0 ? (window.scrollY / h * 100) + '%' : '0%';
    }, { passive: true });
  </script>

  <article class="container py-8 md:py-12">
    <header class="max-w-[680px] mx-auto mb-8">
      <div class="flex items-center gap-3 mb-4">
        <CategoryPill category={category} lang={lang} />
        {type === 'analysis' && (
          <span class="text-xs font-semibold uppercase tracking-wider text-amber-500">
            {t(lang, 'article.analysis')}
          </span>
        )}
      </div>

      <h1 class="font-headline text-3xl md:text-[40px] leading-tight mb-4">
        {title}
      </h1>

      <p class="article-summary text-lg text-[var(--color-text-muted)] mb-4">
        {summary}
      </p>

      <Byline date={publishedAt} readingTime={readingTime} lang={lang} />
      <!-- {slug && <ViewCounter slug={slug} track={true} />} -->

      <hr class="mt-6 border-[var(--color-border)]" />
    </header>

    <div class="prose-article">
      <slot />
    </div>

    {sources.length > 0 && (
      <div class="max-w-[680px] mx-auto mt-10">
        <SourcesList sources={sources} lang={lang} />
      </div>
    )}

    {tags.length > 0 && (
      <div class="max-w-[680px] mx-auto mt-6 flex flex-wrap gap-2">
        {tags.map(tag => (
          <span class="px-3 py-1 text-xs rounded-full bg-[var(--color-surface)] text-[var(--color-text-muted)]">
            {tag}
          </span>
        ))}
      </div>
    )}

    {faqs.length > 0 && (
      <section class="max-w-[680px] mx-auto mt-10 pt-6 border-t border-[var(--color-border)]" aria-labelledby="faq-heading">
        <h2 id="faq-heading" class="font-headline text-2xl mb-4">
          {lang === 'zh' ? '常見問題' : 'Frequently Asked Questions'}
        </h2>
        <div class="flex flex-col gap-4">
          {faqs.map((f) => (
            <details class="border border-[var(--color-border)] rounded-lg p-4">
              <summary class="font-semibold cursor-pointer">{f.question}</summary>
              <div class="mt-2 text-[var(--color-text-muted)]">{f.answer}</div>
            </details>
          ))}
        </div>
      </section>
    )}

    <div class="max-w-[680px] mx-auto mt-8 pt-6 border-t border-[var(--color-border)]">
      <ShareButtons title={title} url={`/${lang}/${category}/${slug}/`} lang={lang} />
    </div>
  </article>

  {relatedSlugs.length > 0 && (
    <RelatedArticles slugs={relatedSlugs} lang={lang} />
  )}
</BaseLayout>
