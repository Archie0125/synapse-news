---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
import '../styles/global.css';
import type { Lang } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  article?: boolean;
  publishedAt?: Date;
  lang?: Lang;
  category?: string;
}

const {
  title,
  description,
  ogImage,
  article = false,
  publishedAt,
  lang = 'en',
  category,
} = Astro.props;

const htmlLang = lang === 'zh' ? 'zh-TW' : 'en';
---

<!DOCTYPE html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+TC:wght@400;500;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet" />
  <SEOHead
    title={title}
    description={description}
    ogImage={ogImage}
    article={article}
    publishedAt={publishedAt}
    lang={lang}
    category={category}
  />
  <script is:inline>
    const theme = localStorage.getItem('theme') ||
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    document.documentElement.setAttribute('data-theme', theme);
  </script>
  <!-- Vercel Web Analytics -->
  <script defer src="/_vercel/insights/script.js"></script>
</head>
<body class="min-h-screen flex flex-col">
  <Header lang={lang} />
  <main class="flex-1">
    <slot />
  </main>
  <Footer lang={lang} />
</body>
</html>
