---
import BaseLayout from './BaseLayout.astro';
import { getCategoryBySlug } from '../lib/categories';
import { getCategoryName, type Lang } from '../lib/i18n';

interface Props {
  category: string;
  lang?: Lang;
}

const { category, lang = 'en' } = Astro.props;
const cat = getCategoryBySlug(category);
const name = getCategoryName(lang, cat.slug);
---

<BaseLayout title={name} lang={lang}>
  <div class="container py-8 md:py-12">
    <header class="mb-8">
      <h1 class="font-headline text-3xl md:text-4xl mb-2">
        {name}
      </h1>
      <div class="h-1 w-16 rounded" style={`background-color: ${cat.color}`}></div>
    </header>

    <slot />
  </div>
</BaseLayout>
