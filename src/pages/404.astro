---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CATEGORIES } from '../lib/categories';
---

<BaseLayout title="Page Not Found" lang="en">
  <div class="container py-16 md:py-24 text-center">
    <h1 class="font-headline text-6xl md:text-8xl mb-4 text-[var(--color-accent)]">404</h1>
    <p class="text-xl md:text-2xl text-[var(--color-text-muted)] mb-8">
      This page doesn't exist or has been moved.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
      <a href="/en/" class="px-6 py-3 bg-[var(--color-accent)] text-white rounded-lg font-medium hover:opacity-90 transition-opacity">
        Go to Homepage
      </a>
      <a href="/zh/" class="px-6 py-3 bg-[var(--color-surface)] text-[var(--color-text)] rounded-lg font-medium hover:bg-[var(--color-border)] transition-colors">
        前往中文首頁
      </a>
    </div>
    <div class="max-w-md mx-auto">
      <p class="text-sm text-[var(--color-text-muted)] mb-3">Or browse by category:</p>
      <div class="flex flex-wrap justify-center gap-2">
        {CATEGORIES.map(cat => (
          <a
            href={`/en/${cat.slug}/`}
            class="px-3 py-1.5 text-sm rounded-full bg-[var(--color-surface)] text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors"
          >
            {cat.slug}
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
