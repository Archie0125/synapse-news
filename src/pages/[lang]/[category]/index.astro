---
import { getCollection } from 'astro:content';
import CategoryLayout from '../../../layouts/CategoryLayout.astro';
import StoryCard from '../../../components/StoryCard.astro';
import { CATEGORIES } from '../../../lib/categories';
import { LANGS, t, type Lang } from '../../../lib/i18n';

export function getStaticPaths() {
  const paths: any[] = [];
  for (const lang of LANGS) {
    for (const cat of CATEGORIES) {
      paths.push({ params: { lang, category: cat.slug } });
    }
  }
  return paths;
}

const lang = Astro.params.lang as Lang;
const { category } = Astro.params;
const allArticles = await getCollection('articles');
const articles = allArticles
  .filter(a => a.data.category === category && a.data.lang === lang)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<CategoryLayout category={category!} lang={lang}>
  {articles.length > 0 ? (
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-x-6">
      {articles.map(article => (
        <StoryCard
          title={article.data.title}
          summary={article.data.summary}
          category={article.data.category}
          publishedAt={article.data.publishedAt}
          slug={article.id}
          content={article.body ?? ''}
          lang={lang}
        />
      ))}
    </div>
  ) : (
    <p class="text-[var(--color-text-muted)] text-lg py-12 text-center">
      {t(lang, 'category.no_articles')}
    </p>
  )}
</CategoryLayout>
