---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import StoryCard from '../../../components/StoryCard.astro';
import SortBar from '../../../components/SortBar.astro';
import { LANGS, t, type Lang } from '../../../lib/i18n';

export function getStaticPaths() {
  return LANGS.map(lang => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const allArticles = await getCollection('articles');
const articles = allArticles
  .filter(a => a.data.lang === lang)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<BaseLayout title={t(lang, 'all.title')} lang={lang}>
  <div class="container py-8 md:py-12">
    <header class="mb-8">
      <h1 class="font-headline text-3xl md:text-4xl mb-2">{t(lang, 'all.title')}</h1>
      <p class="text-[var(--color-text-muted)]">{t(lang, 'all.description')}</p>
      <div class="h-1 w-16 rounded mt-3 bg-[var(--color-accent)]"></div>
    </header>

    {articles.length > 0 ? (
      <>
        <SortBar lang={lang} listId="all-list" />
        <div id="all-list" class="grid md:grid-cols-2 lg:grid-cols-3 gap-x-6">
          {articles.map(article => (
            <StoryCard
              title={article.data.title}
              summary={article.data.summary}
              category={article.data.category}
              publishedAt={article.data.publishedAt}
              slug={article.id}
              content={article.body ?? ''}
              lang={lang}
              featured={article.data.featured}
              trending={article.data.trending}
              type={article.data.type}
            />
          ))}
        </div>
      </>
    ) : (
      <p class="text-[var(--color-text-muted)] text-lg py-12 text-center">
        {t(lang, 'category.no_articles')}
      </p>
    )}
  </div>
</BaseLayout>
